# MySQL — used by docker-compose to provision the DB container.
MYSQL_DATABASE=trojan_market
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=trojan
MYSQL_PASSWORD=change-me-app

# Spring Boot DB — only needed when running the backend OUTSIDE docker-compose
# (when running via compose, the backend service overrides DB_URL to point at the
# `mysql` service hostname).
DB_URL="jdbc:mysql://localhost:3306/trojan_market?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC"
DB_USERNAME=trojan
DB_PASSWORD=change-me-app

# JWT — JWT_SECRET MUST be at least 32 bytes (256 bits) for HS256.
JWT_SECRET=replace-with-a-long-random-string-min-32-bytes
JWT_EXPIRATION_MS=86400000
JWT_ISSUER=trojan-market

# USC SSO — fill in once IdP integration is wired up.
USC_SSO_ENTITY_ID=urn:trojan-market
USC_SSO_IDP_METADATA_URL=https://shibboleth.usc.edu/idp/shibboleth
USC_SSO_CALLBACK_URL=http://localhost:8080/api/v1/auth/sso/callback

# CORS — comma-separated list of allowed origins for the frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite) — populated when running the frontend dev server.
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_WS_URL=http://localhost:8080/api/v1/ws
VITE_API_PROXY_TARGET=http://localhost:8080
